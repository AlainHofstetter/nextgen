@isTest
public with sharing class QRCodeServiceMockResponse implements HttpCalloutMock{
    public QRCodeServiceMockResponse() {
    }

    public HTTPResponse respond(HttpRequest request){
        HttpResponse response = new HttpResponse();
        response.setHeader('Content-Type','application/json');
        response.setHeader('accept', 'image/jpeg');
        if(request.getEndpoint().contains('fail')){
            response.setBody(' ');
            response.setStatusCode(400);
        }else{
            response.setBody('');
            response.setStatusCode(200);
        }
        
        return response;
    }
}
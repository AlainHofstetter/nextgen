<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>Sets PaymentType__c to Private or CompanyCash based on Car__r.PrivateCar__c for CarTravel expenses. Migrated from Process Builder ExpenseCarTravelPaymentTypePrivate.</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Expense_BeforeSave_CarTravelPaymentType {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Expense_BeforeSave_CarTravelPaymentType</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <decisions>
        <name>Check_PrivateCar</name>
        <label>Private Car?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_CompanyCash</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Private</defaultConnectorLabel>
        <rules>
            <name>Is_Private</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Car__r.PrivateCar__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Private</targetReference>
            </connector>
            <label>Is Private</label>
        </rules>
    </decisions>
    <recordUpdates>
        <name>Set_Private</name>
        <label>Set Payment Type Private</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>PaymentType__c</field>
            <value>
                <stringValue>Private</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Set_CompanyCash</name>
        <label>Set Payment Type CompanyCash</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>PaymentType__c</field>
            <value>
                <stringValue>CompanyCash</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_PrivateCar</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.DeveloperName} = &quot;CarTravel&quot;</filterFormula>
        <object>Expense__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
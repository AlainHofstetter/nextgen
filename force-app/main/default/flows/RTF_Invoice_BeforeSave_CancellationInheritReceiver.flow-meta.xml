<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>On create of a Cancellation invoice, inherit InvoiceReceiver from the cancelled invoice. Migrated from Process Builder InvoiceCancellation (was Obsolete).</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Invoice_BeforeSave_CancellationInheritReceiver {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Invoice_BeforeSave_CancellationInheritReceiver</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_InvoiceReceiver</name>
        <label>Set Invoice Receiver</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>InvoiceReceiver__c</field>
            <value>
                <elementReference>$Record.CancellationInvoiceRelation__r.InvoiceReceiver__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_InvoiceReceiver</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.DeveloperName} = &quot;Cancellation&quot;</filterFormula>
        <object>Invoice__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
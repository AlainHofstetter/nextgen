<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>Copies ILVDocumentNr__c to InvoiceILVDocumentNrSearch__c when it changes on ILV invoices. Migrated from Process Builder ILVDocumentNrSearch.</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Invoice_BeforeSave_ILVDocumentNrSearch {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Invoice_BeforeSave_ILVDocumentNrSearch</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_ILVDocumentNrSearch</name>
        <label>Set ILV Document Nr Search</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>InvoiceILVDocumentNrSearch__c</field>
            <value>
                <elementReference>$Record.ILVDocumentNr__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_ILVDocumentNrSearch</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.DeveloperName} = &quot;ILV&quot; AND ISCHANGED({!$Record.ILVDocumentNr__c})</filterFormula>
        <object>Invoice__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
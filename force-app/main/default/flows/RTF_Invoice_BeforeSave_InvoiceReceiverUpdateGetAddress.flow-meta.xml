<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>    <description>This Flow is used to update various fields based on the Invoice Receiver</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Invoice_BeforeSave_InvoiceReceiverUpdateGetAddress {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Invoice_BeforeSave_InvoiceReceiverUpdateGetAddress</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>myRule_1_A1</name>
        <label>UpdateBillingAddress</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>AccountNameLegal__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.Name</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingAddressAddition__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingAddressLine3__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingAddressCountry__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingCountry__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingAddressPOBox__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingPoBox__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingAddressState__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingState__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingAddressStreetNr__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingStreetNr__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingAddressZIP__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingZip__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingAdressCity__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingCity__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>BillingNameAddition__c</field>
            <value>
                <elementReference>$Record.InvoiceReceiver__r.BillingAddressLine2__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>myRule_1_A1</targetReference>
        </connector>
        <filterFormula>OR(
ISNEW(),
AND(
ISCHANGED({!$Record.InvoiceReceiver__c} ),
NOT(ISBLANK({!$Record.InvoiceReceiver__c} ))
)
)</filterFormula>
        <object>Invoice__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>

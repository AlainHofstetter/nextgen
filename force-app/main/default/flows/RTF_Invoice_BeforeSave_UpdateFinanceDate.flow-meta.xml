<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>    <description>This Flow is used to set the Finance Date to Today if the record type is Cancellation.</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Invoice_BeforeSave_UpdateFinanceDate {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Invoice_BeforeSave_UpdateFinanceDate</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>UPDATE_Date</name>
        <label>UPDATE_Date</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>FinanceDate__c</field>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>InvoiceReceiver__c</field>
            <value>
                <elementReference>$Record.CancellationInvoiceRelation__r.InvoiceReceiver__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>UPDATE_Date</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.Name} = &quot;Cancellation&quot;</filterFormula>
        <object>Invoice__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>

<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>Sets AbacusInbox__c = true when Package is SupplierCosts type with SubType AbacusInbox. Migrated from Process Builder PackageSupplierCostsAbacusInbox.</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Package_BeforeSave_SupplierCostsAbacusInbox {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Package_BeforeSave_SupplierCostsAbacusInbox</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_AbacusInbox_True</name>
        <label>Set AbacusInbox True</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>AbacusInbox__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_AbacusInbox_True</targetReference>
        </connector>
        <filterFormula>{!$Record.RecordType.DeveloperName} = &quot;SupplierCosts&quot; AND {!$Record.PackageSubType__c} = &quot;AbacusInbox&quot;</filterFormula>
        <object>Package__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
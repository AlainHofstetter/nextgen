<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>Copies ProjectResponsibleBusiness__c to all child Package__c when InheritProjectResponsibleToPackages__c is true. Migrated from Process Builder ProjectInheritResponisbleToPackage.</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Project_AfterSave_InheritResponsibleToPackages {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Project_AfterSave_InheritResponsibleToPackages</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Package_Responsible</name>
        <label>Update Package Responsible</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>PackageResponsibleBusiness__c</field>
            <value>
                <elementReference>$Record.ProjectResponsibleBusiness__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record.PackagesProjectName__r</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Package_Responsible</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>InheritProjectResponsibleToPackages__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Project__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
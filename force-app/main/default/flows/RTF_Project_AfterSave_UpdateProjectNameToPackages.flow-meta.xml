<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>Propagates Project Name to ProjectNameSearch__c on all child Package__c when Name changes and project has packages. Migrated from Process Builder ProjectUpdateProjectNameToService.</description>
    <environments>Default</environments>
    <interviewLabel>RTF_Project_AfterSave_UpdateProjectNameToPackages {!$Flow.CurrentDateTime}</interviewLabel>
    <label>RTF_Project_AfterSave_UpdateProjectNameToPackages</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Package_ProjectNameSearch</name>
        <label>Update Package Project Name Search</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>ProjectNameSearch__c</field>
            <value>
                <elementReference>$Record.Name</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record.PackagesProjectName__r</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Package_ProjectNameSearch</targetReference>
        </connector>
        <filterFormula>ISCHANGED({!$Record.Name}) AND {!$Record.ValHasPackage__c}</filterFormula>
        <object>Project__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
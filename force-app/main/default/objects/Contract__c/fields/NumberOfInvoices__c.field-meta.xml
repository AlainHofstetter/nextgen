<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NumberOfInvoices__c</fullName>
    <externalId>false</externalId>
    <formula>IF( InitialFee__c &gt; 0, 
(ContractTermMonths__c ) / 
(CASE(InvoiceCycle__c, &quot;Monthly&quot;, 1,
(CASE(InvoiceCycle__c, &quot;Quarterly&quot;, 3,
(CASE(InvoiceCycle__c, &quot;Yearly&quot;, 12,
0
)))))) +1, (ContractTermMonths__c ) / 
(CASE(InvoiceCycle__c, &quot;Monthly&quot;, 1,
(CASE(InvoiceCycle__c, &quot;Quarterly&quot;, 3,
(CASE(InvoiceCycle__c, &quot;Yearly&quot;, 12,
0
)))))))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Number of Invoices</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>

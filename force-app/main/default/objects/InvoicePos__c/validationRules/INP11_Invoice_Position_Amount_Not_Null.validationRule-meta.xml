<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>INP11_Invoice_Position_Amount_Not_Null</fullName>
    <active>true</active>
    <description>Invoice Position can not be empty</description>
    <errorConditionFormula>AND(
$User.PS480FunctionValidationRulesActive__c =true ,
ISBLANK( InvoicePositionAmount__c )
)</errorConditionFormula>
    <errorDisplayField>InvoicePositionAmount__c</errorDisplayField>
    <errorMessage>The invoice position amount can not be empty. Please add a value or 0.
(INP11)</errorMessage>
</ValidationRule>

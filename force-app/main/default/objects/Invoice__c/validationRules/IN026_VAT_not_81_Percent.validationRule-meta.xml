<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IN026_VAT_not_81_Percent</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
$User.IsFinanceManager__c = false,
$User.PS480FunctionValidationRulesActive__c =true, 
ISPICKVAL(VATPercent__c, &quot;8.1%&quot;),
ISPICKVAL(InvoiceStatus__c ,&quot;Ready&quot;),
ISPICKVAL(InvoiceStatus__c ,&quot;Sent&quot;)
)</errorConditionFormula>
    <errorDisplayField>VATPercent__c</errorDisplayField>
    <errorMessage>You are not allowed to choose VAT 8.1%. Please get in touch with Finance. 
(IN026)</errorMessage>
</ValidationRule>

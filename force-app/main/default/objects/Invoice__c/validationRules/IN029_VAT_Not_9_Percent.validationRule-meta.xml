<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IN029_VAT_Not_9_Percent</fullName>
    <active>true</active>
    <description>You are not allowed to choose VAT 9%. Please get in touch with Finance. 
(IN029)</description>
    <errorConditionFormula>AND(
NOT(CONTAINS( BillingViaCompany__r.AccountName__c , &quot;gateB (Singpore)&quot;)),
$User.IsFinanceManager__c = false,
$User.PS480FunctionValidationRulesActive__c =true, 
ISPICKVAL(VATPercent__c, &quot;9%&quot;)
)</errorConditionFormula>
    <errorDisplayField>VATPercent__c</errorDisplayField>
    <errorMessage>You are not allowed to choose VAT 9%. Please get in touch with Finance. 
(IN029)</errorMessage>
</ValidationRule>

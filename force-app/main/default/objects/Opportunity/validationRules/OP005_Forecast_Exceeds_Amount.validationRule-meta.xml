<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>OP005_Forecast_Exceeds_Amount</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
 $User.PS480FunctionValidationRulesActive__c =true,
 TotalForecastCurrentYear__c &gt; Amount 
)</errorConditionFormula>

<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>OP006_Account_Inactive</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
$User.PS480FunctionValidationRulesActive__c =true, 
ISNEW(),
Account.Inactive__c =true
)</errorConditionFormula>
    <errorDisplayField>AccountId</errorDisplayField>
    <errorMessage>This Contract Partner is Inactive, therefore you can not create a new Project. Please get in touch with Finance. 
(OP006)</errorMessage>
</ValidationRule>

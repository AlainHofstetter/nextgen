<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>QL012_Entry_Invalid_Superior_Line_Item</fullName>
    <active>false</active>
    <errorConditionFormula>AND( 
NOT(ISBLANK( SuperiorQuoteLineItem__c )), 
NOT(ISPICKVAL(  SuperiorQuoteLineItem__r.ProductType__c ,&quot;Group&quot;)) 
)</errorConditionFormula>
    <errorMessage>Superior Product must be of Product Type &quot;Group&quot; 
(QL012)</errorMessage>
</ValidationRule>

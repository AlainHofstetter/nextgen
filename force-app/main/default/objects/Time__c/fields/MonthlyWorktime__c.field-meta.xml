AND(
TimetrackerCompany__r.Id &lt;&gt; &quot;001b000000Ppj5P&quot;,
YEAR(DateFrom__c)=2017
),
CASE( IsInBillingPeriodYearMonth__c,&quot;2017.1&quot;,176,&quot;2017.2&quot;,160,&quot;2017.3&quot;,184,&quot;2017.4&quot;,144,&quot;2017.5&quot;,176,&quot;2017.6&quot;,160,&quot;2017.7&quot;,168,&quot;2017.8&quot;,176,&quot;2017.9&quot;,168,&quot;2017.10&quot;,176,&quot;2017.11&quot;,168,&quot;2017.12&quot;,152,0)

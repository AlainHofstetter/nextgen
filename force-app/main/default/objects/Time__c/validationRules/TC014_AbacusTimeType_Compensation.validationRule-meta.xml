    <fullName>TC014_AbacusTimeType_Compensation</fullName>
    <active>true</active>
    <description>Only user with rights can change Abacus Time Type</description>
    <errorConditionFormula>AND(
 $User.PS480FunctionValidationRulesActive__c =true,

					    '   <td>'+
					    '		<a href="" onclick="ColapseMenu('+tablename+');return false;" aria-controls="expando-unique-id" aria-expanded="true" class="slds-button slds-section__title-action" id="search-section-button">'+
			            '       	<svg class="slds-section__title-action-icon slds-button__icon slds-button__icon_left" aria-hidden="true">'+
			            '   	       <use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="{!URLFOR($Resource.SLDS246, '/assets/icons/utility-sprite/svg/symbols.svg#switch')}" />'+
			            ' 			</svg>'+
			            '    	</a>'+
					    '	</td>'+                            
                        '   <td>'+ 
                     	'        <input type="checkbox" class ="packageInputSelect" data-i='+i+' id="selected'+i+'"' + 'onchange="selectSons('+tablename+');return false;"  />'+                     
                        '        <label  class="slds-truncate packageName" title="name">'+replaceUndefined(row.name)+'</label>'+
                        '   </td>'+
                        '   <td>'+
                        '        <label class="slds-truncate packagesortNumber" title="sortNumber">'+replaceUndefined(row.sortNumber)+'</label>'+
                        '   </td>'+
                        '   <td>'+
                        '        <div class="slds-truncate packageDescription" title="description">'+replaceUndefined(row.description)+'</div>'+
                        '   </td>'+   
                        '   <td>'+
                        '        <div class="slds-truncate packagetotalPrice" title="totalPrice" id= "TotalPriceParent' +i+'">'+replaceUndefined(row.totalPrice)+'</div>'+
                        '   </td>'+ 
                        '   <td>'+
                        '        <div class="slds-truncate packageID slds-hide" title="bundlePackage">'+replaceUndefined(row.bundlePackage)+'</div>'+
                        '   </td>'+                         
                        '</tr>';
                       
                        if(row.listPackageItems.length != 0) {
                       	   tableHTML +='<tr><td colspan="4"><table class = "slds-section slds-is-open slds-show packageitems"  data-i='+i+' id = "packageItemsTable'+i+'">'+                  	   
	                       '	 <thead>'+
	                       ' 		<tr class="slds-text-title_caps tableHeader">'+	                       			
	                       ' 			<th scope="col" class="tableHeader" data-priority="1" style="width:24%;">'+
	                       '   				<div class="slds-truncate" title="Name">'+
	                       '        			Name'+
	                       '   				</div>'+
	                       '  			</th>'+
	                       '  			<th scope="col" class="tableHeader" data-priority="1" style="width:24%;">'+
	                       '    			<div class="slds-truncate" title="ProductType">'+
	                       '       				Fraction'+
	                       '   				</div>'+
	                   	   '            </th>'+
	                   	   '            <th scope="col" class="tableHeader" data-priority="1" style="width:24%;">'+
	                       '               <div class="slds-truncate" title="Defaultprice">'+
	                       '                  Default price'+
	                       '               </div>'+
	                       '        	</th>'+
	                       '       		<th scope="col" class="tableHeader" data-priority="1" style="width:24%;">'+

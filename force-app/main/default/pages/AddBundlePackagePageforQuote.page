/******************************************************************************/
//GET PACKAGES FUNCTION 

            function getPackages() {
            
                var nameSearch = myJq('#nameinput').val();
                var SortNumber = myJq('#SortNumberInput').val();
                
                if(nameSearch != null) { filterFields.name = nameSearch;}
                if(SortNumber != null) { filterFields.SortNumber = SortNumber;}
                        
                AddBundlePackageController.queriePackages(JSON.stringify(filterFields),
                    function(result, event){
                        if(event.status){
                            if (result == null || result.startsWith("ERROR|")){
                                var errorMsg;
                                if (result)
                                    errorMsg = result.split("|")[1];
                                else
                                    errorMsg = 'Error';

                                   showError("#error-messages-div",errorMsg);
                                   
                                   return true;
                             }else {                
                                    PackageTemplates = JSON.parse(cleanJSON(result));                     
                                    buildTable(PackageTemplates);                                   
                                    showError("#sucess-messages-div",PackageTemplates.length + " Packages found");
                                    PackageTemplates = null;
                                    return true;
                             }
                        }
                            
                          }                    
                   );
        
                return false;
                            
            }
         	
/******************************************************************************/
//BUILD TABLE FUNCTION 
      	

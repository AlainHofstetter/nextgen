/******************************************************************************/
// ADD PACKAGES FUNCTION 
            function addPackages(){
            
                var myjson = [];
                var WrapperPackage;     
                var newwrapperpackage = true;   
                
                myJq(".packageTable").find('tr').each(function(i, el) {
                                        
                    var row = myJq(this);
                    
                    if (row.find('input[type="checkbox"]').is(':checked')) {
                                            
                        if(row.hasClass('packagerow') && newwrapperpackage) {
                                                                                                    
                            WrapperPackage = {"selected":"true",
                                                "name":"name",
                                                "sortNumber":"sortNumber",
                                                "description":"description",
                                                "totalPrice":"totalPrice",  
                                                "bundlePackage":"bundlePackage",
                                                "QuoteId":QuoteId,
                                                "PricebookId":pricebookEntry,
                                                "listPackageItems":[]}; 
                            
                            WrapperPackage.name = row.find('.packageName').text().trim();
                            WrapperPackage.sortNumber = row.find('.packagesortNumber').text().trim();
                            WrapperPackage.description = row.find('.packageDescription').text().trim();
                            WrapperPackage.totalPrice = row.find('.packagetotalPrice').text().trim();
                            WrapperPackage.bundlePackage = row.find('.packageID').text().trim();
            
                            newwrapperpackage = false;
                        }
                                                                        
                        row.find('tr').each(function(i, el) {
                                                                                
                            var line = myJq(this);                  
                                                
                            if (line.hasClass('sonsData') && line.find('input[type="checkbox"]').is(':checked') ){
                                
                                var WrapperPackageItem = {
                                            "selected":"true",
                                            "name":"name",
                                            "ProductType":"ProductType",
                                            "Defaultprice":"Defaultprice",
                                            "Defaultquantity":"Defaultquantity",    
                                            "Totalprice":"Totalprice"
                                };
                                
                                WrapperPackageItem.name = line.find('td.sonName').text().trim();
                                WrapperPackageItem.ProductType = line.find('td.sonProductType').text().trim();
                                WrapperPackageItem.Defaultprice = line.find('td.sonDefaultPrice input').val();
                                WrapperPackageItem.Defaultquantity = line.find('td.sonDefaultQuantity input').val();
                                WrapperPackageItem.Totalprice = line.find('td.sonTotalPrice').text().trim();
                                WrapperPackageItem.productId = line.find('td.sonID').text().trim(); 
                                                                                    
                                WrapperPackage.listPackageItems.push(WrapperPackageItem);
                                
                                newwrapperpackage = true;                           
                            }
                        });
                   
                    }
                    
                     if(newwrapperpackage) {
                        if(WrapperPackage!=null){
                            myjson.push(WrapperPackage);
                        }
                        WrapperPackage = null;

                     }
                    
                                
                });
                
                
                
                AddBundlePackageController.addToQuote(JSON.stringify(myjson),
                    
                    function(result, event){
                        if(event.status){
                            if (result == null || result.startsWith("ERROR|")){
                                var errorMsg;
                                if (result)
                                    errorMsg = result.split("|")[1];
                                else
                                    errorMsg = 'test';

                                   showError("#error-messages-div",errorMsg);
                                   
                                   return true;
                             }else {                
                                                                        
                                    showError("#sucess-messages-div",result + "");
                                    
                                    return true;
                             }
                        }
                            
                          }                    
                   );
                
                return false;
            }
 /******************************************************************************/
//recalculate total functions
	

	
	function calculateTotalLineSon(idpackageItemsTr) {
		
		var line = myJq('#'+idpackageItemsTr);
		line.find('td.sonTotalPrice').text(line.find('td.sonDefaultPrice input').val() *line.find('td.sonDefaultQuantity input').val() * 1);
		   			
		if (line.find('input[type="checkbox"]').is(':checked')) {

			var parent = document.getElementById(idpackageItemsTr);
			calculateTotalPriceParent(parent.dataset.parent);
		}
		return null;
	}
		

	function calculateTotalPriceParent(dataparentnumber) {

		var parent = document.getElementById('parent'+dataparentnumber);
		var sonlenght = parent.dataset.sonslenght;
		
		var newTotal = Number(0);
		for( j = 0; j<sonlenght; j++) {
			
			if( myJq('#'+'sonRow'+dataparentnumber + j).find('input[type="checkbox"]').is(':checked')) {				
				newTotal += Number(myJq('#sonRow'+dataparentnumber + j).find('td.sonTotalPrice').text());				
			}		
		}
		myJq('#TotalPriceParent'+dataparentnumber).text(newTotal);

		return null;
	}

		                             
/******************************************************************************/
//SELECT SONS FUNCTION

        function selectSons(parentname){
        
            myJq.find(parentname)
            myJq("#"+parentname ).find("input:checkbox").prop('checked', true);
            
            return false;
                        
        }               
            
            
/******************************************************************************/                        
            
//COLAPSABLE FUNCTION
            
            function ColapseMenu(obj) {
            
                if (myJq("#"+obj).hasClass('slds-show')){
                  
                    myJq('#'+obj).removeClass('slds-show');
                    myJq('#'+obj).addClass('slds-hide');
                 }else {
                    myJq('#'+obj).removeClass('slds-hide');
                    myJq('#'+obj).addClass('slds-show');
                    
                 
                }                                    
                return false;  
            }
                    
/******************************************************************************/            
//STANDARD UTILITY FUNCTIONS
            
 
            /*
             * Clears error message from the provided div and hides div
             */
            function clearErrors(errorDiv) {
                myJq(errorDiv).addClass("slds-hide");
                myJq(errorDiv).html("");
            }
              /*
             * Replaces undefined or null strings with an empty string.
             */
            function replaceUndefined(str) {
            
                if (!str)
                    return 'aaaaaaaaa';
                else
                    return str;
            }
            
            function deleteTargetCom(index) {
                console.log(index);
                addedcallitems.splice(index,1);
                buildTable(addedcallitems);
            }
            
            /*
             * Cleans JSON string
             */
            function cleanJSON(jsonStr) {
                return jsonStr.replace(/&quot\;/g,"\"")
                  .replace(/\n/g,"")
                  .replace(/\r/g,"")
                  .replace(/&amp\;/g,"&");
            }
                /*
             * Displays given error message at the provided div and shows div
             */
            function showError(errorDiv, errorMsg) {
                
                
                myJq(errorDiv).removeClass('slds-hide');
                myJq(errorDiv).html(errorMsg);
                return false;
            }
            
         
        </script>
            

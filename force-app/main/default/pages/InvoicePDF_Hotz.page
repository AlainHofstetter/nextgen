<!-- https://brandleadership--dev1--c.sandbox.vf.force.com/apex/InvoicePDF_Hotz?id=a0QFT000007lLI02AM -->
<apex:page standardController="Invoice__c" extensions="InvoiceDocumentController" showHeader="false" sidebar="false"
    renderAs="pdf" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" action="{!getImageURL}" language="{!IF(invoiceRecord.AccountLanguage__c == 'DE', 'de_CH', 'en_CH')}">
    
    <head>
        <style>
          
            @page :first {
                margin-bottom: 360px !important;
                margin-left: 0 !important;
                margin-right: 0 !important;
                font-family: 'Helvetica', sans-serif;

                @bottom-left {
                    content: element(imageFirstPage);
                }
                @bottom-center{

                }

                @bottom-right {
                    content: none;
                }
                @top-center {
                    /*nothing*/
                }
            }

            @page {
                margin-top: 100px !important;
                margin: .50in .70in 1in 0.80in;
                font-size: 75%;
                font-family: 'Helvetica', sans-serif;

                @bottom-center {
                    height: 8px !important;
                    width: 20px !important;
                    content: element(footer);
                    margin-left: -50px;
                    font-weight: normal;
                    font-family: 'Helvetica', sans-serif;
                }
                @bottom-right {
                    content: "Seite: " counter(page) " / " counter(pages);
                    font-size: 65%;
                    font-family: 'Helvetica', sans-serif;
                }

                @top-right {
                    content: element(header);
                }
            }

            .page-break {
                display: block;
                page-break-after: always;
            }

            div.header {
              display: block;
              position: running(header);
              font-family: 'Helvetica', sans-serif;
            }
            div.footer-hotz {
                display: block;
                font-size: 55%;
                text-align: center;
                position: running(footer);
                margin-left: -50px;
                font-family: 'Helvetica', sans-serif;
            }

            div.content table {
                -fs-table-paginate: paginate;
            }

            .p {
                page-break-inside: avoid;
                font-weight: normal;
            }
            
            .head_col_1 {
                width: 35%;
            }
            .head_col_2 {
                width: 30%;
            }
            .head_col_3 {
                width: 35%;
            }

            .col_1 {
                width: 30%;
                vertical-align: top;
            }

            .col_2 {
                width: 5%;
            }

            .col_3 {
                width: 45%;
                vertical-align: top;
            }
            .contentFirstPage {
              font-family: 'Helvetica', sans-serif;
            }

            .col35{
                width: 33%;
            }
            .col50{
                width: 50%;
            }
            .tableLargeCol{
                width: 90%;
            }
            .tableSmallCol{
                width: 10%;
                align-content: right;
            }
            .borderBottom{
                border-bottom: 1pt solid black;
            }
            .highlight{
                /*font-weight: bold;*/
                border-bottom: 1pt solid black;
            }

            .highlightLight{
              border-bottom: 0.5pt solid black;
            }

            .content{
                padding-top: 10px;
                font-family: 'Helvetica', sans-serif;
            }
            
            .textFirstPage{
                padding-top: 0px;
                /* margin: .2in .70in 1in 1.25in; */
                margin-left: 1.25in;
                margin-right: .70in;

                /* width: 100%; */
            }
            .projNameFirstPage{
                padding-top:15px;
                padding-bottom: 25px;
                width: 200px;
            }
            div.imageFirstPage{
                display: block;
                object-fit: cover;
                position: running(imageFirstPage);
            }

            /* Font size */
            .font14{
              font-size: 14px;
            }
            .font70 {
              font-size: 70%;
            }
            .font80 {
              font-size: 80%;
            }
            .font90 {
              font-size: 90%;
            }
            .font95 {
              font-size: 95%;
            }
            .font100 {
              font-size: 100%;
            }
            .font110 {
              font-size: 110%;
            }
            .font120 {
              font-size: 120%;
            }
            .font130 {
              font-size: 130%;
            }
            .font150 {
              font-size: 150%;
            }
            .font200{
                font-size:200%;
            }
            .bold{
              font-weight: bold;
            }
            .uppercase {
              text-transform: uppercase;
            }
            .alignRight{
              text-align: right;
            }


            /* Paddings */
            .paddingFirstTable{
                padding-top: -50px;
            }
            .paddingTopTable{
                padding-top: 15px;
            }
            .paddingBottom10{
                padding-bottom: 10px;
            }
            .paddingBottom20{
                padding-bottom: 20px;
            }
            .paddingBotom30{
                padding-bottom: 20px;
            }
            .paddingTop10{
                padding-top: 10px;
            }
            .paddingTop20{
                padding-top: 20px;
            }
            .paddingTop30{
                padding-top:30px;
            }
            .paddingTop40{
                padding-top: 40px;
            }
            .rightColPadding{
                padding-top: 20px;
            }
            .paddingGroup{
                padding-top: 25px;
            }
            .margin_bottom{
                padding-bottom: 30px;
            }
            .hidden {
                display: none;
            }

            /* applies only to your summary table */
            table.invoiceTable { border-collapse: collapse; }

            /* Only the vertical compacting knobs */
            table.invoiceTable td,
            table.invoiceTable th {
                padding: 2pt 4pt;     /* reduce row height */
                line-height: 1.3;     /* tighter text inside cells */
            }

            /* kill default margins inside cells that add extra vertical space */
            table.invoiceTable p,
            table.invoiceTable div,
            table.invoiceTable span {
                margin: 0;
                line-height: inherit;
            }

            /* guardrails—keep amount behaving like a table cell, not a float */
            table.invoiceTable td.amount {
                text-align: right;
                white-space: nowrap;
                display: table-cell !important;
                float: none !important;
            }
        </style>
    </head>

    <div class="header">
       
    </div>
    
    
    <div class="footer-hotz">
        <apex:image url="{!$Resource.hotz_logo}" width="120"/>
    </div>

    <!-- FIRST PAGE -->
    <div class="contentFirstPage" >
        <div class="textFirstPage">
          <table >
                <tr>
                    <td class="col_1 font80">
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.AccountNameLegal__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.AccountNameLegal__c))}">
                        <apex:outputField value="{!invoiceRecord.AccountNameLegal__c}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.BillingNameAddition__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingNameAddition__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingNameAddition__c}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.BillingAddressStreetNr__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingAddressStreetNr__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingAddressStreetNr__c}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.BillingAddressAddition__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingAddressAddition__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingAddressAddition__c}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.BillingAddressPOBox__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingAddressPOBox__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingAddressPOBox__c}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="inline" styleClass="{!IF(ISBLANK(invoiceRecord.BillingAddressZIP__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingAddressZIP__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingAddressZIP__c}" />&nbsp;
                    </apex:outputPanel>
                    <apex:outputPanel layout="inline" styleClass="{!IF(ISBLANK(invoiceRecord.BillingAdressCity__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingAdressCity__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingAdressCity__c}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.BillingAddressState__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingAddressState__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingAddressState__c}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.BillingAddressCountry__c), 'hidden', '')}" rendered="{!NOT(ISBLANK(invoiceRecord.BillingAddressCountry__c))}">
                        <apex:outputField value="{!invoiceRecord.BillingAddressCountry__c}" /><br/>
                    </apex:outputPanel>
                    </td>

                    <td class="col_3 alignRight font80">
                      {!$Label.hotz_header1} <br/>
                      {!$Label.hotz_header2} <br/>
                      {!$Label.hotz_header3} <br/> <br/>
                      {!$Label.hotz_header4}
                    </td>
                </tr>
            </table>
          <table class="paddingTop40">
              <tr>
                <td class="bold font200 paddingBottom20">
                    <apex:outputText value="{!invoiceRecord.InvoiceTitle__c}"></apex:outputText>
                </td>    
              </tr>
              <tr>
                <td class="font130 bold paddingBottom20">
                  <apex:outputField value="{!invoiceRecord.ProjectName__r.Name}"></apex:outputField>
                </td>    
              </tr>
              <tr>
                <td class="paddingBottom20 font14">
                  {!localisedDate}
                </td>    
              </tr>
              <tr>
                  <td class="font80 bold">
                      {!$Label.InvoiceNr}
                  </td>
              </tr>
              <tr>
                  <td class="font80">
                      <apex:outputText value="{!IF(invoiceRecord.InvoiceStatus__c = 'Draft', 'DRAFT Invoice',invoiceRecord.InvoiceDocumentNr__c)}" />
                  </td>
              </tr>
              <tr>
                <td class="bold paddingTop10 font80">
                   <apex:outputText rendered="{!!ISBLANK(invoiceRecord.OpportunityQuoteNr__c)}" value="{!$Label.offer_nr}"></apex:outputText><br/>
                </td>
              </tr>
              <tr>
                <td class="font80">
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.OpportunityQuoteNr__c), 'hidden', '')}">
                        <apex:outputField value="{!invoiceRecord.OpportunityQuoteNr__c}" /><br/>
                    </apex:outputPanel>
                </td>
              </tr>
              <tr>
                <td class="bold paddingTop10 font80">
                  {!$Label.InvoiceContact}
                </td>
              </tr>
              <tr>
                <td class="font80">
                  <apex:outputField value="{!invoiceRecord.InvoiceContact__r.FirstName}"></apex:outputField>&nbsp;
                  <apex:outputField value="{!invoiceRecord.InvoiceContact__r.LastName}"></apex:outputField><br/>
                  <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.InvoiceContact__r.Phone), 'hidden', '')}">
                        <apex:outputField value="{!invoiceRecord.InvoiceContact__r.Phone}" /><br/>
                    </apex:outputPanel>
                    <apex:outputPanel layout="block" styleClass="{!IF(ISBLANK(invoiceRecord.InvoiceContact__r.Email), 'hidden', '')}">
                        <apex:outputText value="{!invoiceRecord.InvoiceContact__r.Email}" /><br/>
                    </apex:outputPanel>
                </td>
              </tr>
              <tr>
                <td class="bold paddingTop10 font80">
                  <!-- <apex:outputText rendered="{!!ISBLANK(invoiceRecord.CustomerReference__c )}" value="{!$Label.Reference}"></apex:outputText> -->
                   <span class="rightColPadding bold">
                        <apex:outputText value="{!$Label.your_reference}"
                            rendered="{!NOT(ISBLANK(invoiceRecord.CustomerReference__c))}" />

                        <apex:outputText value="&nbsp;/&nbsp;" escape="false"
                            rendered="{!AND(NOT(ISBLANK(invoiceRecord.CustomerReference__c)),
                                            NOT(ISBLANK(invoiceRecord.CustomerOrderNr__c)))}" />

                        <apex:outputText value="{!$Label.po_nr}"
                            rendered="{!NOT(ISBLANK(invoiceRecord.CustomerOrderNr__c))}" />

                        <apex:outputText value=":" 
                            rendered="{!OR(NOT(ISBLANK(invoiceRecord.CustomerReference__c)),
                                        NOT(ISBLANK(invoiceRecord.CustomerOrderNr__c)))}" />
                    </span>
                </td>
              </tr>
              <tr>
                <td class="font80">
                    <!-- <apex:outputText rendered="{!!ISBLANK(invoiceRecord.CustomerReference__c )}" value="{!invoiceRecord.CustomerReference__c}"></apex:outputText>
                    <apex:outputText rendered="{!!ISBLANK(invoiceRecord.CustomerOrderNr__c )}" value=" / {!invoiceRecord.CustomerOrderNr__c}"></apex:outputText> -->
                    <span class="rightColPadding">
                        <apex:outputText value="{!invoiceRecord.CustomerReference__c}"
                            rendered="{!NOT(ISBLANK(invoiceRecord.CustomerReference__c))}" />

                        <apex:outputText value="&nbsp;/&nbsp;" escape="false"
                            rendered="{!AND(NOT(ISBLANK(invoiceRecord.CustomerReference__c)),
                                            NOT(ISBLANK(invoiceRecord.CustomerOrderNr__c)))}" />

                        <apex:outputText value="{!invoiceRecord.CustomerOrderNr__c}"
                            rendered="{!NOT(ISBLANK(invoiceRecord.CustomerOrderNr__c))}" />
                    </span>
                </td>
              </tr>
          </table>
        </div>


        <apex:outputPanel rendered="{!invoiceRecord.InvoiceReceiver__r.BillingCountry__c == 'SWITZERLAND' &&
                                    (invoiceRecord.ProjectInvoiceCurrency__c == 'CHF' || invoiceRecord.ProjectInvoiceCurrency__c == 'EUR')}">
            <div class="imageFirstPage" style="margin:0; padding:0;">
                <apex:image url="{!imageURL}" width="815px" style="max-width:815px;" />
            </div>
        </apex:outputPanel>
    </div>
    
    <!-- SECOND PAGE -->
    <div style="page-break-before:always;" class="content">
        <body style="font-size:85%;font-weight:normal; font-family: 'Helvetica', sans-serif;color:#010101">
            


            <table border="0" cellspacing="0" cellpadding="0" width="75%" class="invoiceTable">
                <tr>
                    <td class="font200 bold" >{!$Label.period_summary}</td>
                    <td class="amount"></td>
                </tr>
                <tr>
                    <td class="paddingBottom10">
                        {!localisedPeriodFrom} - {!localisedPeriodUntil}
                    </td>
                    <td class="amount"></td>
                </tr>
                <tr>
                    <td >
                        <apex:outputField rendered="{!invoiceRecord.ShowProjectInvoiceDescription__c == true}" value="{!invoiceRecord.InvoiceDescription__c}"></apex:outputField> 
                    </td>
                    <td class="amount"></td>
                </tr>
                
                <!-- MAIN TABLE -->

                <tr >
                    <td class="tableLargeCol"></td>
                    <td class="tableSmallCol uppercase alignRight bold"> {!invoiceRecord.ProjectInvoiceCurrency__c}</td>
                </tr>

                <apex:repeat value="{!invPosGroupKeys}" var="groupName" >
                    <!-- Invoice positions group -->
                    <tr>
                        <td class="tableLargeCol bold paddingGroup borderBottom highlightLight" ><apex:outputField value="{!mapGroupNameAmount[groupName].InvoicePositionName__c}"/> </td>
                        <td class="tableSmallCol alignRight bold  paddingGroup borderBottom highlightLight"> <apex:outputField value="{!mapGroupNameAmount[groupName].InvoicePositionAmount__c}"/></td>
                    </tr>
                    
                    <!-- Invoice positions belonging to the group -->
                    <apex:repeat value="{!mapInvPosGroup[groupName]}" var="invPos" >
                      <tr>
                            <!-- <apex:outputPanel layout="none" rendered="{!!(ISBLANK(invPos.InvoicePositionAmount__c))}"> -->
                                <td class="tableLargeCol paddingTopTable">
                                    <apex:outputPanel layout="none" rendered="{!!(ISBLANK(invPos.InvoicePositionAmount__c))}">
                                        <apex:outputField value="{!invPos.InvoicePositionName__c}"/>
                                    </apex:outputPanel>
                                </td>
                                <td class="tableSmallCol alignRight paddingTopTable">
                                    <apex:outputPanel layout="none" rendered="{!!(ISBLANK(invPos.InvoicePositionAmount__c))}">
                                    <!-- JC updated 25/03/2026 from the following line to the rest of the code inside this td
                                        <apex:outputField value="{!invPos.InvoicePositionAmount__c}"/>
                                    -->
                                        <apex:outputPanel layout="none" rendered="{!invPos.ShowPositionAmount__c}">
                                            <apex:outputField value="{!invPos.InvoicePositionAmount__c}"/>
                                        </apex:outputPanel>
                                    </apex:outputPanel>
                                </td>
                            <!-- </apex:outputPanel> -->
                            <!-- <apex:outputPanel layout="none" rendered="{!(ISBLANK(invPos.InvoicePositionText__c))}">
                                <td class="tableLargeCol paddingTopTable bold borderBottom highlightLight">
                                    -----4-----<br/>
                                    <apex:outputField value="{!invPos.InvoicePositionName__c}"/>
                                </td>
                                <td class="tableSmallCol alignRight paddingTopTable borderBottom highlightLight">
                                    <apex:outputField value="{!invPos.InvoicePositionAmount__c}"/>
                                </td>
                            </apex:outputPanel> -->
                        </tr>
                        <apex:outputPanel layout="none" rendered="{!!(ISBLANK(invPos.InvoicePositionText__c))}">
                            <tr>
                                <td class="tableLargeCol borderBottom highlightLight">
                                    <apex:outputField value="{!invPos.InvoicePositionText__c}"/>
                                </td>
                                <td class="tableSmallCol alignRight paddingTopTable borderBottom highlightLight">
                                </td>
                            </tr>
                        </apex:outputPanel>
                    </apex:repeat>
                </apex:repeat>

                <apex:repeat value="{!nonGroupInvPos}" var="invPos">
                  <tr>
                      <apex:outputPanel layout="none" rendered="{!!(ISBLANK(invPos.InvoicePositionText__c))}">
                          <td class="tableLargeCol paddingTopTable">
                              <apex:outputField value="{!invPos.InvoicePositionName__c}"/>
                          </td>
                          <td class="tableSmallCol alignRight paddingTopTable">
                              <apex:outputField value="{!invPos.InvoicePositionAmount__c}"/>
                          </td>
                      </apex:outputPanel>
                      <apex:outputPanel layout="none" rendered="{!(ISBLANK(invPos.InvoicePositionText__c))}">
                          <td class="tableLargeCol paddingTopTable borderBottom highlightLight">
                              <apex:outputField value="{!invPos.InvoicePositionName__c}"/>
                          </td>
                          <td class="tableSmallCol alignRight paddingTopTable borderBottom highlightLight">
                            <!-- JC updated 25/03/2026 from the following line to the rest of the code inside this td
                                <apex:outputField value="{!invPos.InvoicePositionAmount__c}"/>
                            -->
                                <apex:outputPanel layout="none" rendered="{!invPos.ShowPositionAmount__c}">
                                    <apex:outputField value="{!invPos.InvoicePositionAmount__c}"/>
                                </apex:outputPanel>
                          </td>
                      </apex:outputPanel>
                  </tr>
                  <apex:outputPanel layout="none" rendered="{!!(ISBLANK(invPos.InvoicePositionText__c))}">
                      <tr>
                          <td class="tableLargeCol borderBottom highlightLight">
                              <apex:outputField value="{!invPos.InvoicePositionText__c}"/>
                          </td>
                          <td class="tableSmallCol alignRight paddingTopTable borderBottom highlightLight">
                          </td>
                      </tr>
                  </apex:outputPanel>
                </apex:repeat>

                <!--AFTER LOOP Total Amounts-->

                <tr >
                    <td class="tableLargeCol borderBottom paddingTop40 bold">{!$Label.Total_Amount} </td>
                    <td class="tableSmallCol borderBottom alignRight paddingTop40 bold" > 
                        <apex:outputField value="{!invoiceRecord.InvoiceTotalAmountNet__c}"></apex:outputField>
                    </td>
                </tr>

                <tr>
                    <td class="tableLargeCol highlightLight paddingTopTable">{!$Label.VAT_Amount} &nbsp;{!invoiceRecord.VATPercent__c} </td>
                    <td class="tableSmallCol highlightLight alignRight paddingTopTable"> 
                        <apex:outputField value="{!invoiceRecord.InvoiceVATAmount__c}"></apex:outputField>
                    </td>
                </tr>

                <tr>
                    <td class="tableLargeCol uppercase highlight bold paddingTopTable">{!$Label.Total_Gross} {!invoiceRecord.ProjectInvoiceCurrency__c} {!$Label.INKL_VAT} </td>
                    <td class="tableSmallCol highlight alignRight bold paddingTopTable"> 
                        <apex:outputField value="{!invoiceRecord.InvoiceTotalAmountGross__c}"></apex:outputField>
                    </td>
                </tr>
            <!-- </tbody> -->
            </table>

            <div class="paddingBottom10 paddingTop40">
                 {!$Label.TermsPayment}&nbsp;{!termsOfPaymentLabel}
            </div>
            <div class="paddingBotom30">
                 {!$Label.VAT_Footer} &nbsp;
            </div>
            <div class="">
                <apex:outputField value="{!invoiceRecord.BankName__c}"></apex:outputField>,&nbsp;
                <apex:outputField value="{!invoiceRecord.BankLocation__c}"></apex:outputField><br/>
                {!$Label.IBAN}&nbsp;<apex:outputField value="{!invoiceRecord.IBAN__c}"></apex:outputField>,&nbsp;
                {!$Label.Bank_Clearing}&nbsp;<apex:outputField value="{!invoiceRecord.BankClearing__c}"></apex:outputField>,&nbsp;
                {!$Label.SWIFT}&nbsp;<apex:outputField value="{!invoiceRecord.SWIFT__c}"></apex:outputField>
            </div>
        </body>
    </div>

</apex:page>
<?xml version='1.0' encoding='UTF-8'?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Account_Update_Previous_Owner_Change</fullName>
        <description>Account: Update Previous Owner Change</description>
        <protected>false</protected>
        <recipients>
            <field>ZEmailCurrentOwner__c</field>
            <type>email</type>
        </recipients>
        <recipients>
            <field>ZEmailPreviousOwner__c</field>
            <type>email</type>
        </recipients>
        <senderAddress>noreply@brandleadership.ch</senderAddress><senderType>OrgWideEmailAddress</senderType>
        <template>CS_Templates/Account_Update_Account_Owner_Change</template>
    </alerts>
    <alerts>
        <fullName>CS_Agency_Checkbox</fullName>
        <description>CS - Agency Checkbox</description>
        <protected>false</protected>
        <recipients><type>owner</type></recipients><senderAddress>noreply@brandleadership.ch</senderAddress><senderType>OrgWideEmailAddress</senderType>
        <template>CS_Templates/CS_Agency_Checkbox</template>
    
        <recipients><recipient>sascha.salis@brandleadership.ch</recipient><type>email</type></recipients>
        <recipients><recipient>technicaluser@brandleadership.ch</recipient><type>email</type></recipients>
    </alerts>
    <alerts>
        <fullName>CS_New_Account_from_PrintPlus</fullName>
        <ccEmails>om@brandleadership.ch</ccEmails>
        <description>CS - New Account from PrintPlus</description>
        <protected>false</protected>
        <senderAddress>noreply@brandleadership.ch</senderAddress><senderType>OrgWideEmailAddress</senderType>
        <template>CS_Templates/CS_New_Account_from_PrintPlus</template>
    </alerts>
    <alerts>
        <fullName>CS_Premium_Checkbox</fullName>
        <description>CS - Premium Checkbox</description>
        <protected>false</protected>
        <recipients><type>owner</type></recipients><senderAddress>noreply@brandleadership.ch</senderAddress><senderType>OrgWideEmailAddress</senderType>
        <template>CS_Templates/CS_Premium_Checkbox</template>
    
        <recipients><recipient>rahel.hotz@hieronymus-cp.com</recipient><type>email</type></recipients>
    </alerts>
    <fieldUpdates>
        <fullName>Account_Update_Email_Current_Owner</fullName>
        <field>ZEmailCurrentOwner__c</field>
        <formula>Owner.Email</formula>
        <name>Account: Update Email Current Owner</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Account_Update_Email_Previous_Owner</fullName>
        <field>ZEmailPreviousOwner__c</field>
        <formula>PRIORVALUE( ZEmailCurrentOwner__c )</formula>
        <name>Account: Update Email Previous Owner</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Account%3A Update Account Owner Send Email</fullName>
        <actions>
            <name>Account_Update_Previous_Owner_Change</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <formula>ISCHANGED( ZEmailPreviousOwner__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Account%3A Update Email Previous %26 Current Owner</fullName>
        <actions>
            <name>Account_Update_Email_Current_Owner</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Account_Update_Email_Previous_Owner</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>ISCHANGED(OwnerId)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>CS - Agency Checkbox</fullName>
        <actions>
            <name>CS_Agency_Checkbox</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Account.Agency__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <description>This Workflow is used to inform about AGENCY=TRUE</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>CS - Premium Checkbox</fullName>
        <actions>
            <name>CS_Premium_Checkbox</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Account.Premium__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <description>This Workflow is used to inform about PREMIUM=TRUE</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
</Workflow>
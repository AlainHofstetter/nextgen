<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>CS_IT_Support_Case_Closed_Auto_Mail</fullName>
        <description>CS - IT Support Case Closed Auto Mail</description>
        <protected>false</protected>
        <recipients>
            <field>ContactEmail</field>
            <type>email</type>
        </recipients>
        <senderAddress>noreply@brandleadership.ch</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>z_Sample_Temlates/SUPPORT_Close_Case_with_Solution</template>
    </alerts>
    <fieldUpdates>
        <fullName>CS_IT_Support_Case_Auto_Closed</fullName>
        <field>Status</field>
        <literalValue>Closed</literalValue>
        <name>CS - IT Support Case Auto-Closed</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>CS - IT Support Case Auto-Closed</fullName>
        <actions>
            <name>CS_IT_Support_Case_Auto_Closed</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <booleanFilter>(1 OR 2 or (4 AND 5) or (6 AND 7)) AND 3</booleanFilter>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Quarantäne-Übersicht</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Quarantine Summary</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.RecordTypeId</field>
            <operation>equals</operation>
            <value>IT Cases</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Clariion Alert</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Description</field>
            <operation>contains</operation>
            <value>DIMM1</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Google Apps Directory Sync</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>SUCCESS</value>
        </criteriaItems>
        <description>IT Cases are closed automatically when created as they are not of importance (e.g. Antwort Quarantäne...)</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>CS - IT Support Case Closed Auto Mail</fullName>
        <actions>
            <name>CS_IT_Support_Case_Closed_Auto_Mail</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <booleanFilter>1 AND 2 AND (3 OR 4 OR 5 OR 6 OR 7 OR 8 OR 9 OR 10 OR 11 OR 12 OR 13 OR 14 OR 15 OR 16 OR 17) AND 18</booleanFilter>
        <criteriaItems>
            <field>Case.Status</field>
            <operation>equals</operation>
            <value>Closed</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.RecordTypeId</field>
            <operation>equals</operation>
            <value>IT Cases</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.ContactEmail</field>

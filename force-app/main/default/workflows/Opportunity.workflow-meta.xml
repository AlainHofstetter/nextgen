    <fieldUpdates>
        <fullName>Amount_GB_License</fullName>
        <description>Calculates the Amount of the Opportunity of GB - License for internal forecast.</description>
        <field>Amount</field>
        <formula>IF(ProfessionalServicesGB__c&gt;0, ModulesEntireTermGB__c + ProfessionalServicesGB__c + OneTimeTechinicalSetupGB__c +  HostingGB__c , ModulesEntireTermGB__c + OneTimeTechinicalSetupGB__c + HostingGB__c)</formula>
        <name>Amount GB-License</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Amount_GB_SAS_License</fullName>
        <field>Amount</field>
        <formula>AmountSAS__c * LicencePercentageGB__c</formula>
        <name>Amount GB - SAS License</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>

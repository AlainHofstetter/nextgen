    <rules>
        <fullName>CS - Opportunity LOST</fullName>
        <actions>
            <name>CS_Opportunity_LOST</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <description>This Workflow is used to inform about Opportunity Stage = LOST</description>
        <formula>AND(
ispickval(StageName,&quot;Closed Lost&quot;),
ischanged( StageName )
)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
